# Supabase — publishable (anon) credentials for the opt-in leaderboard.
# Copy to .env.local and fill in. Safe to expose in the browser (RLS protects
# the table). If unset, the analyzer still works; only the leaderboard is offline.
#
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is the preferred name (Supabase's newer
# sb_publishable_… key). The legacy NEXT_PUBLIC_SUPABASE_ANON_KEY also works.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — used by @supabase/server/core createAdminClient (bypasses RLS).
# Get it from: Supabase dashboard → Project Settings → API Keys → secret key (sb_secret_...).
# In production this lives as a Cloudflare Worker secret: wrangler secret put SUPABASE_SECRET_KEY
SUPABASE_URL=
SUPABASE_SECRET_KEY=
