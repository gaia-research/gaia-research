# Wrangler local dev vars — copy to .dev.vars and fill in.
# Used by `wrangler dev` / OpenNext local preview against the Workers runtime.
# Wrangler does NOT read .env.local, so these must live here for local previews.
# Safe to expose in the browser at build time (RLS protects the table).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — used by @supabase/server/core createAdminClient (bypasses RLS).
# In production: wrangler secret put SUPABASE_SECRET_KEY
SUPABASE_URL=
SUPABASE_SECRET_KEY=
